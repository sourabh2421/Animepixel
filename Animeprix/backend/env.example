PORT=3001
FRONTEND_URL=http://localhost:5173
# Preferred variable in production (Render)
CONSUMET_URL=http://localhost:3002/anime
# Prefer API_BASE_URL for the third-party consumer API.
API_BASE_URL=http://localhost:3002/anime
# Backward compatibility (optional). If API_BASE_URL is set, this is ignored.
CONSUMET_API_URL=http://localhost:3002/anime

# If your provider requires auth, set API_KEY and optionally enforce it at startup.
API_KEY=
API_KEY_REQUIRED=false
